modules = ["nodejs-20"]

run = "npx -y pnpm@9 build && npx -y pnpm@9 start"
entrypoint = "apps/server/src/index.ts"

[deployment]
build = ["sh", "-c", "npx -y pnpm@9 install && npx -y pnpm@9 build"]
run = ["sh", "-c", "npx -y pnpm@9 start"]

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true
